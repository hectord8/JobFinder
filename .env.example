# ---------------------------------------------------------------------------
# Database (PostgreSQL — Supabase or Neon)
# ---------------------------------------------------------------------------
# Supabase: use the "Connection pooling" string for DATABASE_URL and the
# "Direct connection" string for DIRECT_URL (needed by Prisma Migrate).
# Neon: use the pooled (-pooler) URL for DATABASE_URL and the direct URL here.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
# Your app's base URL (http://localhost:3000 in dev).
NEXTAUTH_URL="http://localhost:3000"

# Optional: lock down account creation.
# ALLOW_REGISTRATION="false"
# REGISTRATION_ALLOWLIST="you@example.com"

# ---------------------------------------------------------------------------
# Cron protection
# ---------------------------------------------------------------------------
# Vercel sends "Authorization: Bearer $CRON_SECRET" to the cron route.
# Generate: openssl rand -hex 32
CRON_SECRET="replace-me"

# ---------------------------------------------------------------------------
# File storage for CVs
# STORAGE_DRIVER = local | supabase | blob
# ---------------------------------------------------------------------------
STORAGE_DRIVER="local"

# --- Supabase Storage (STORAGE_DRIVER=supabase) ---
# Create a bucket (default name "cvs"). Service role key is server-side only.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="cvs"

# --- Vercel Blob (STORAGE_DRIVER=blob) ---
# Create a Blob store in the Vercel dashboard; it injects this token.
BLOB_READ_WRITE_TOKEN=""

# ---------------------------------------------------------------------------
# Job provider API keys (all optional — a provider auto-disables if unset)
# ---------------------------------------------------------------------------
# Adzuna: https://developer.adzuna.com/
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# Reed (UK): https://www.reed.co.uk/developers
REED_API_KEY=""

# Jooble: https://jooble.org/api/about
JOOBLE_API_KEY=""

# JSearch via RapidAPI (Indeed/LinkedIn/Glassdoor aggregator):
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_RAPIDAPI_KEY=""

# Arbeitnow needs no key.

# USAJobs (US gov; optional): https://developer.usajobs.gov/
USAJOBS_API_KEY=""
USAJOBS_USER_AGENT="your-email@example.com"

# ---------------------------------------------------------------------------
# Matching algorithm
# MATCH_ALGORITHM = tfidf | embedding
# ---------------------------------------------------------------------------
MATCH_ALGORITHM="tfidf"
# Required only when MATCH_ALGORITHM=embedding.
OPENAI_API_KEY=""

# ---------------------------------------------------------------------------
# Seed user (npm run db:seed)
# ---------------------------------------------------------------------------
SEED_EMAIL="you@example.com"
SEED_PASSWORD="changeme123"
